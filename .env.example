# =============================================================================
# 🌸 Mirai Helix - Environment Configuration
# =============================================================================
# Salin file ini menjadi .env dan isi nilai yang sesuai.
#   cp .env.example .env
#
# Variabel yang ditandai (wajib) HARUS diisi agar bot bisa berjalan.
# Variabel (opsional) dapat dikosongkan jika tidak digunakan.
# =============================================================================

# =============================================================================
# 🎮 DISCORD — (wajib)
# =============================================================================
# Token bot Discord dari Discord Developer Portal.
# https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# =============================================================================
# 🧠 GEMINI — (wajib) Multi-Provider AI #1
# =============================================================================
# Google Gemini API key(s). Bisa lebih dari satu, dipisahkan koma.
# Key akan dirotasi otomatis jika salah satu terkena rate limit / cooldown.
# https://aistudio.google.com/apikey
GEMINI_KEYS=your_gemini_key_1,your_gemini_key_2

# =============================================================================
# 🚀 NVIDIA NIM — (opsional) Multi-Provider AI #2
# =============================================================================
# API key untuk DeepSeek V4 Pro / V4 Flash via NVIDIA NIM.
# Diperlukan jika ingin menggunakan perintah /deepseek.
# https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# =============================================================================
# ⚡ GROQ — (opsional) Multi-Provider AI #3
# =============================================================================
# Groq API key untuk fallback AI (Llama 3) dan ringkasan berita RSS.
# Diperlukan jika Gemini mengalami error.
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# 🧬 MICRO-RAG — (opsional) Profiling User via Groq
# =============================================================================
# API key khusus untuk Micro-RAG (profil kepribadian user).
# Bisa menggunakan key yang sama dengan GROQ_API_KEY, atau key terpisah.
# Jika dikosongkan, fitur profiling user dinonaktifkan.
GROQ_API_KEY_M_RAG=your_groq_api_key_for_micro_rag

# =============================================================================
# 🌐 WEB SCRAPING — (opsional) Browserless
# =============================================================================
# API key untuk Browserless.io — digunakan untuk scraping konten website
# saat user mengirim link Discord. Jika dikosongkan, fitur web search mati.
# https://www.browserless.io/
BROWSERLESS_API_KEY=your_browserless_api_key_here

# Base URL Browserless. Hanya ubah jika menggunakan self-hosted Browserless.
# Default: https://chrome.browserless.io
# BROWSERLESS_BASE_URL=https://chrome.browserless.io

# =============================================================================
# 🚨 MONITORING — (opsional)
# =============================================================================
# Webhook URL untuk notifikasi sistem (CPU tinggi, error dll).
# Biarkan kosong jika tidak ingin notifikasi.
WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Channel ID Discord untuk mengirim embed peringatan (mis: CPU > 70%).
# Biarkan 0 jika tidak ingin alert.
ALERT_CHANNEL_ID=0

# =============================================================================
# ⏭️ BYPASS COOLDOWN — (opsional)
# =============================================================================
# Daftar channel ID yang BEBAS dari cooldown respons (dipisahkan koma).
# Berguna untuk channel khusus bot / admin.
# Biarkan kosong jika tidak ada channel yang di-bypass.
BYPASS_CHANNEL_IDS=123456789012345678,987654321098765432

# =============================================================================
# 📝 LOGGING — (opsional)
# =============================================================================
# Level logging: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Default: INFO
MIRAI_LOG_LEVEL=INFO

# Path file log (opsional). Jika diisi, log juga ditulis ke file.
# Biarkan kosong untuk log hanya di console.
MIRAI_LOG_FILE=server.log

# =============================================================================
# ⚙️ CONFIGURASI TAMBAHAN — (opsional, sudah ada default di config.py)
# =============================================================================
# Guild/Server ID untuk development (opsional).
# Catatan: Router saat ini hanya melakukan global sync (guild-specific sync dinonaktifkan
# untuk menghindari double command). Variabel ini disediakan untuk referensi.
# GUILD_ID=your_discord_guild_id

# ---- Contoh / Tips ----
# Discord Token:           https://discord.com/developers/applications → Bot → Token
# Gemini Key:              https://aistudio.google.com/apikey
# NVIDIA NIM Key:          https://build.nvidia.com/ → Sign In → API Key
# Groq Key:                https://console.groq.com/keys
# Browserless Key:         https://www.browserless.io/ → Dashboard → API Token
